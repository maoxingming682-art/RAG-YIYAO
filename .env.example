# Copy this file to .env and fill in your own keys.
# Never commit .env.

# Optional single fallback API
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=glm-4.7-flash

# Multi-provider failover used by src/llm_pool.py
LLM_API_1_NAME=agentrs
LLM_API_1_BASE_URL=https://agentrs.jd.com/api/saas/openai-u/v1
LLM_API_1_KEY=
LLM_API_1_MODEL=GLM-5.1
LLM_API_1_PRIORITY=1

LLM_API_2_NAME=keungliang
LLM_API_2_BASE_URL=https://keungliang.dpdns.org/v1
LLM_API_2_KEY=
LLM_API_2_MODEL=glm-5.2
LLM_API_2_PRIORITY=2

LLM_API_3_NAME=zhenhaoji
LLM_API_3_BASE_URL=https://api.zhenhaoji.qzz.io/v1
LLM_API_3_KEY=
LLM_API_3_MODEL=glm-4.7-flash
LLM_API_3_PRIORITY=3
